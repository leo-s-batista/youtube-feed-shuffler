{
  "manifest_version": 3,
  "name": "YouTube Feed Shuffler",
  "description": "Busca termos no YouTube e abre vídeos em sequência para diversificar recomendações.",
  "version": "0.1.0",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_title": "YouTube Feed Shuffler",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
